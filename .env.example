# PULSE Configuration
# Copy to .env and fill in your values

# Required
ANTHROPIC_API_KEY=sk-ant-...

# Database (default works with nix develop)
DATABASE_URL=postgresql://localhost:5432/pulse

# Optional: Exchange API (leave empty for price-only mode)
# EXCHANGE_API_KEY=
# EXCHANGE_SECRET=

# App
DEBUG=false
CCXT_SANDBOX=true
